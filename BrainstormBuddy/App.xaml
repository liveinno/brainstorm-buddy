<Application x:Class="BrainstormBuddy.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Иконки мержатся внутри темы (IconsDark/IconsLight) и меняются вместе с ней -->
                <ResourceDictionary Source="Themes/HackerTheme.xaml"/>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
                <ResourceDictionary Source="Resources/Strings.ru.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- Размер шрифта контента оверлея — управляется настройкой Ui.FontSize.
                 Обновляется в OverlayWindow.ApplyContentFontSize(); DynamicResource-биндинги
                 текста вопроса/ответа подхватывают изменение вживую. -->
            <sys:Double x:Key="OverlayAnswerFontSize">15</sys:Double>
            <sys:Double x:Key="OverlayQuestionFontSize">13.5</sys:Double>
        </ResourceDictionary>
    </Application.Resources>
</Application>
