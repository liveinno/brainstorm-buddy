<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Набор иконок 5a «контур 1.8px» — пути 1:1 из newdesign/Icon Sets.dc.html (для светлой темы).
         Базовый штрих #3a4657 → IconBrush темы. Ключи совпадают с IconsDark.xaml. -->

    <Style x:Key="StrokeA" TargetType="Path">
        <Setter Property="Stroke" Value="{DynamicResource IconBrush}"/>
        <Setter Property="StrokeThickness" Value="1.8"/>
        <Setter Property="StrokeStartLineCap" Value="Round"/>
        <Setter Property="StrokeEndLineCap" Value="Round"/>
        <Setter Property="StrokeLineJoin" Value="Round"/>
    </Style>

    <Viewbox x:Key="IconAppLogo" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Style="{StaticResource StrokeA}" Data="M4 12h.01M20 12h.01M8 8.5v7M12 5.5v13M16 9.5v5"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconChevronDown" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Style="{StaticResource StrokeA}" Data="M7 10l5 5 5-5"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconLlm" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Rectangle Canvas.Left="4.5" Canvas.Top="7" Width="15" Height="11.5" RadiusX="4" RadiusY="4"
                       Stroke="{DynamicResource IconBrush}" StrokeThickness="1.8"/>
            <Rectangle Canvas.Left="7.6" Canvas.Top="10.4" Width="8.8" Height="4.2" RadiusX="2.1" RadiusY="2.1"
                       Stroke="{DynamicResource IconBrush}" StrokeThickness="1.8"/>
            <Ellipse Canvas.Left="9.45" Canvas.Top="11.55" Width="1.9" Height="1.9" Fill="{DynamicResource IconBrush}"/>
            <Ellipse Canvas.Left="12.65" Canvas.Top="11.55" Width="1.9" Height="1.9" Fill="{DynamicResource IconBrush}"/>
            <Ellipse Canvas.Left="10.8" Canvas.Top="3.3" Width="2.4" Height="2.4"
                     Stroke="{DynamicResource IconBrush}" StrokeThickness="1.8"/>
            <Path Style="{StaticResource StrokeA}" Data="M12 5.8V7"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconPause" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Data="M9 6v12M15 6v12" Stroke="{DynamicResource IconBrush}" StrokeThickness="2.6"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconPlay" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Data="M8 5.5l11 6.5-11 6.5z" Fill="{DynamicResource WarnBrush}"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconAutoScroll" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Style="{StaticResource StrokeA}" Data="M12 4v11M7.5 10.5L12 15l4.5-4.5M6 20h12"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconSettings" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Style="{StaticResource StrokeA}" Data="M4 7.5h7.5M16.5 7.5H20M4 16.5h3.5M12.5 16.5H20"/>
            <Ellipse Canvas.Left="11.9" Canvas.Top="5.4" Width="4.2" Height="4.2" Stroke="{DynamicResource IconBrush}" StrokeThickness="1.8"/>
            <Ellipse Canvas.Left="7.9" Canvas.Top="14.4" Width="4.2" Height="4.2" Stroke="{DynamicResource IconBrush}" StrokeThickness="1.8"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconMinimize" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Style="{StaticResource StrokeA}" Data="M6 12h12"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconMaximize" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Rectangle Canvas.Left="5" Canvas.Top="5" Width="14" Height="14" RadiusX="2.5" RadiusY="2.5"
                       Stroke="{DynamicResource IconBrush}" StrokeThickness="1.8"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconClose" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Data="M6.5 6.5l11 11M17.5 6.5l-11 11" Stroke="{DynamicResource CloseIconBrush}" StrokeThickness="1.8"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconSendNow" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Data="M14.6 3.2L7 12.4h4.2L9.6 20.8l7.6-9.2H13z" Stroke="{DynamicResource BoltBrush}" StrokeThickness="1.8"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconExport" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Style="{StaticResource StrokeA}" Data="M12 3.5V13M8 9.5l4 4 4-4M4.5 16.5V19A1.5 1.5 0 0 0 6 20.5h12a1.5 1.5 0 0 0 1.5-1.5v-2.5"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconExportDone" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Data="M5 12.5l4.5 4.5L19 7.5" Stroke="{DynamicResource SuccessIconBrush}" StrokeThickness="2.4"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconAiProtocol" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Style="{StaticResource StrokeA}" Data="M6.5 3.5h7l4 4v13h-11z M13.5 3.5V8h4 M12 10.2l.85 1.95 1.95.85-1.95.85L12 15.8l-.85-1.95-1.95-.85 1.95-.85z M9.5 18h5"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconScreenshot" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Style="{StaticResource StrokeA}" Data="M8.5 7l1.6-2.5h3.8L15.5 7"/>
            <Rectangle Canvas.Left="3.5" Canvas.Top="7" Width="17" Height="13" RadiusX="2.5" RadiusY="2.5"
                       Stroke="{DynamicResource IconBrush}" StrokeThickness="1.8"/>
            <Ellipse Canvas.Left="8.8" Canvas.Top="10" Width="6.4" Height="6.4" Stroke="{DynamicResource IconBrush}" StrokeThickness="1.8"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconSlowSpeech" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Style="{StaticResource StrokeA}" Data="M4.5 16a7.5 7.5 0 0 1 15 0 M12 16L8 12.6"/>
            <Ellipse Canvas.Left="10.65" Canvas.Top="14.65" Width="2.7" Height="2.7" Fill="{DynamicResource IconBrush}"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconResetSpeed" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Style="{StaticResource StrokeA}" Data="M4.5 16a7.5 7.5 0 0 1 15 0 M12 16v-5.2 M9.9 5.2L12 3.4l2.1 1.8"/>
            <Ellipse Canvas.Left="10.65" Canvas.Top="14.65" Width="2.7" Height="2.7" Fill="{DynamicResource IconBrush}"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconFastSpeech" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Style="{StaticResource StrokeA}" Data="M4.5 16a7.5 7.5 0 0 1 15 0 M12 16l4-3.4"/>
            <Ellipse Canvas.Left="10.65" Canvas.Top="14.65" Width="2.7" Height="2.7" Fill="{DynamicResource IconBrush}"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconCloak" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Data="M3.5 12S6.5 6.5 12 6.5 20.5 12 20.5 12 17.5 17.5 12 17.5 3.5 12 3.5 12z"
                  Stroke="{DynamicResource IconBrush}" StrokeThickness="1.8" StrokeDashArray="1.78 1.44"/>
            <Ellipse Canvas.Left="9.5" Canvas.Top="9.5" Width="5" Height="5" Stroke="{DynamicResource IconBrush}" StrokeThickness="1.8"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconErase" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Data="M4.8 7.2h14.4 M10 7.2V6a1.6 1.6 0 0 1 1.6-1.6h.8A1.6 1.6 0 0 1 14 6v1.2 M6.2 7.2l1.1 10.9a2.2 2.2 0 0 0 2.2 2h5a2.2 2.2 0 0 0 2.2-2l1.1-10.9 M12 10.8v5.6"
                  Stroke="{DynamicResource ErrorBrush}" StrokeThickness="1.8"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconMic" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Rectangle Canvas.Left="9.5" Canvas.Top="3.5" Width="5" Height="10" RadiusX="2.5" RadiusY="2.5"
                       Stroke="{DynamicResource IconBrush}" StrokeThickness="1.8"/>
            <Path Style="{StaticResource StrokeA}" Data="M6.5 11.5a5.5 5.5 0 0 0 11 0M12 17v3.5M9 20.5h6"/>
        </Canvas>
    </Viewbox>

    <!-- «LLM выкл»: перечёркнутый чат-пузырь (контурная версия для светлой темы,
         просвет вокруг черты — под-штрих BgBrush, как в IconsDark) -->
    <Viewbox x:Key="IconLlmOff" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Rectangle Canvas.Left="3.5" Canvas.Top="5" Width="17" Height="11" RadiusX="3.5" RadiusY="3.5"
                       Stroke="{DynamicResource IconBrush}" StrokeThickness="1.8"/>
            <Path Style="{StaticResource StrokeA}" Data="M7.5 16v4l4.3-4"/>
            <Ellipse Canvas.Left="7.1" Canvas.Top="9.6" Width="1.8" Height="1.8" Fill="{DynamicResource IconBrush}"/>
            <Ellipse Canvas.Left="11.1" Canvas.Top="9.6" Width="1.8" Height="1.8" Fill="{DynamicResource IconBrush}"/>
            <Ellipse Canvas.Left="15.1" Canvas.Top="9.6" Width="1.8" Height="1.8" Fill="{DynamicResource IconBrush}"/>
            <Path Data="M4.5 20.5L19.5 3.5" Stroke="{DynamicResource BgBrush}" StrokeThickness="4"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            <Path Style="{StaticResource StrokeA}" Data="M4.5 20.5L19.5 3.5"/>
        </Canvas>
    </Viewbox>

    <!-- «Динамик выкл»: перечёркнутый динамик с волнами (контурная версия) -->
    <Viewbox x:Key="IconSpeakerOff" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Style="{StaticResource StrokeA}" Data="M4.5 9.5h2.7L12 5.5v13l-4.8-4H4.5z"/>
            <Path Style="{StaticResource StrokeA}" Data="M15.5 9.2a4 4 0 0 1 0 5.6"/>
            <Path Style="{StaticResource StrokeA}" Data="M18 6.8a7.6 7.6 0 0 1 0 10.4"/>
            <Path Data="M4.5 20.5L19.5 3.5" Stroke="{DynamicResource BgBrush}" StrokeThickness="4"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            <Path Style="{StaticResource StrokeA}" Data="M4.5 20.5L19.5 3.5"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconChatSend" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Style="{StaticResource StrokeA}" Data="M20.5 3.5L3.5 10.5l6 2.2L11 20l3.5-5.5 6-11z M9.5 12.7L20.5 3.5"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconStop" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Rectangle Canvas.Left="6.5" Canvas.Top="6.5" Width="11" Height="11" RadiusX="2" RadiusY="2"
                       Stroke="{DynamicResource ErrorBrush}" StrokeThickness="1.8"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconChevronRight" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Style="{StaticResource StrokeA}" Data="M10 7l5 5-5 5"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconHome" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Style="{StaticResource StrokeA}" Data="M4.5 11.5L12 4.5l7.5 7M6.5 10v9.5h4v-5h3v5h4V10"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconCalendar" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Rectangle Canvas.Left="3.5" Canvas.Top="5" Width="17" Height="15.5" RadiusX="2.5" RadiusY="2.5"
                       Stroke="{DynamicResource IconBrush}" StrokeThickness="1.8"/>
            <Path Style="{StaticResource StrokeA}" Data="M8 3v4M16 3v4M3.5 10.5h17"/>
        </Canvas>
    </Viewbox>

    <Viewbox x:Key="IconInfo" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Ellipse Canvas.Left="3.5" Canvas.Top="3.5" Width="17" Height="17" Stroke="{DynamicResource IconBrush}" StrokeThickness="1.8"/>
            <Path Style="{StaticResource StrokeA}" Data="M12 11v5"/>
            <Path Data="M12 8h.01" Stroke="{DynamicResource IconBrush}" StrokeThickness="2.4" StrokeStartLineCap="Round"/>
        </Canvas>
    </Viewbox>
    <Viewbox x:Key="IconHelp" x:Shared="False" Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Ellipse Canvas.Left="3.5" Canvas.Top="3.5" Width="17" Height="17" Stroke="{DynamicResource IconBrush}" StrokeThickness="1.8"/>
            <Path Style="{StaticResource StrokeA}" Data="M12 11v5"/>
            <Path Data="M12 8h.01" Stroke="{DynamicResource IconBrush}" StrokeThickness="2.4" StrokeStartLineCap="Round"/>
        </Canvas>
    </Viewbox>

</ResourceDictionary>
