    <sys:String x:Key="L_Last2Min">last 2 min</sys:String>

    <sys:String x:Key="L_TT_Minimize">Minimize</sys:String>
    <sys:String x:Key="L_TT_Maximize">Maximize / restore</sys:String>

</ResourceDictionary>
