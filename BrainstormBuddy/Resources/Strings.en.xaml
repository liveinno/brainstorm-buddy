                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Localization: English. Keys MUST match Strings.ru.xaml. -->

    <!-- Overlay: zones -->
    <sys:String x:Key="L_Listening">Listening…</sys:String>
    <sys:String x:Key="L_ColdStartTitle">Warming up speech recognition</sys:String>
    <sys:String x:Key="L_ColdStartBody">First launch is warming up — answers will appear a few seconds after speech begins.</sys:String>
    <sys:String x:Key="L_Question">QUESTION</sys:String>
    <sys:String x:Key="L_Answer">ANSWER</sys:String>
    <sys:String x:Key="L_HrdAdvice">HR ADVICE</sys:String>
