    <sys:String x:Key="L_Save">Save</sys:String>
    <sys:String x:Key="L_CloseBtn">Close</sys:String>
    <sys:String x:Key="L_OpenFolder">Open folder</sys:String>
    <sys:String x:Key="L_CheckConnection">Check connection</sys:String>
    <sys:String x:Key="L_Language">Язык интерфейса / Language:</sys:String>
