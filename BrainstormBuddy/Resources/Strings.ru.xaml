<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Локализация: русский. Парный файл — Strings.en.xaml (ключи ДОЛЖНЫ совпадать).
         Переключение: App.ApplyLanguage(), настройка Config.Ui.Language. -->

    <!-- Оверлей: зоны -->
    <sys:String x:Key="L_Listening">Слушаю…</sys:String>
    <sys:String x:Key="L_ColdStartTitle">Готовлю распознавание речи</sys:String>
    <sys:String x:Key="L_ColdStartBody">Первый запуск прогревается — ответы появятся через несколько секунд после начала речи.</sys:String>
    <sys:String x:Key="L_Question">ВОПРОС</sys:String>
    <sys:String x:Key="L_Answer">ОТВЕТ</sys:String>
    <sys:String x:Key="L_HrdAdvice">HRD СОВЕТ</sys:String>
    <sys:String x:Key="L_Defense">ЗАЩИТА</sys:String>
    <sys:String x:Key="L_Expanded">РАСШИРЕННЫЙ ОТВЕТ</sys:String>
    <sys:String x:Key="L_Silence">ТИШИНА</sys:String>
    <sys:String x:Key="L_ChunkMax">ЧАНК МАКС</sys:String>
    <sys:String x:Key="L_Audio">АУДИО</sys:String>
    <sys:String x:Key="L_TokensFmt">Токены: {0:N0}  (in {1:N0} / out {2:N0})</sys:String>
    <sys:String x:Key="L_SecretHint">Секретное сообщение в LLM…</sys:String>
