    <!-- Оверлей: контекст-меню -->
    <sys:String x:Key="L_CM_CopyAll">Копировать всё на экране</sys:String>
    <sys:String x:Key="L_CM_CopyHistory">Копировать всю историю (за сессию)</sys:String>
    <sys:String x:Key="L_CM_CopyQuestion">Копировать вопрос</sys:String>
    <sys:String x:Key="L_CM_CopyAnswer">Копировать ответ</sys:String>
    <sys:String x:Key="L_CM_Expand">Ответить расширенно</sys:String>
    <sys:String x:Key="L_CM_ClearExpanded">Сбросить расширенный ответ</sys:String>
    <sys:String x:Key="L_CM_Focus">Фокус на этой паре</sys:String>
    <sys:String x:Key="L_CM_ClearFocus">Снять фокус со всех</sys:String>

    <!-- Статусы (из кода) -->
    <sys:String x:Key="L_St_AudioPaused">Аудио на паузе</sys:String>
    <sys:String x:Key="L_St_LlmPaused">LLM на паузе — аудио записывается</sys:String>
    <sys:String x:Key="L_St_Thinking">Думаю…</sys:String>
    <sys:String x:Key="L_St_NoConnection">Нет соединения с сервером</sys:String>
    <sys:String x:Key="L_SttQueueFmt">STT: {0} в очереди · {1:F1}с в буфере</sys:String>

    <!-- Настройки: сайдбар -->
    <sys:String x:Key="L_Tab_Api">API</sys:String>
    <sys:String x:Key="L_Tab_Llm">LLM</sys:String>
    <sys:String x:Key="L_Tab_Audio">Аудио</sys:String>
    <sys:String x:Key="L_Tab_LocalStt">Распознавание речи (STT)</sys:String>
    <sys:String x:Key="L_Tab_Overlay">Оверлей</sys:String>
    <sys:String x:Key="L_Tab_Hotkeys">Горячие клавиши</sys:String>
    <sys:String x:Key="L_Tab_About">О приложении</sys:String>
    <sys:String x:Key="L_Tab_Profile">Резюме</sys:String>
    <sys:String x:Key="L_Tab_Agents">Агенты</sys:String>
    <sys:String x:Key="L_Tab_LlmLogs">Диагностика</sys:String>

    <!-- Настройки: футер и общее -->
    <sys:String x:Key="L_Save">Сохранить</sys:String>
    <sys:String x:Key="L_CloseBtn">Закрыть</sys:String>
    <sys:String x:Key="L_OpenFolder">Открыть папку</sys:String>
    <sys:String x:Key="L_CheckConnection">Проверить подключение</sys:String>
    <sys:String x:Key="L_Language">Язык интерфейса / Language:</sys:String>
    <sys:String x:Key="L_Theme">Тема оформления:</sys:String>

    <sys:String x:Key="L_SendBtn">Отправить</sys:String>
    <sys:String x:Key="L_Last2Min">последние 2 мин</sys:String>

    <sys:String x:Key="L_TT_Minimize">Свернуть</sys:String>
    <sys:String x:Key="L_TT_Maximize">Развернуть</sys:String>

</ResourceDictionary>
