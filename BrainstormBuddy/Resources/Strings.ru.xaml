    <sys:String x:Key="L_AgentsSilent">(агенты промолчали)</sys:String>
    <sys:String x:Key="L_MicNoted">🎧 ваша реплика — учтена в контексте</sys:String>

    <!-- Оверлей: тултипы -->
    <sys:String x:Key="L_TT_Preset">Активный системный промпт для LLM</sys:String>
    <sys:String x:Key="L_TT_Rec">Запись аудио</sys:String>
    <sys:String x:Key="L_TT_Llm">Отправка в LLM</sys:String>
    <sys:String x:Key="L_TT_LlmPause">Пауза LLM (Ctrl+Shift+Y)</sys:String>
    <sys:String x:Key="L_TT_AudioPause">Пауза аудио (Ctrl+Shift+P)</sys:String>
    <sys:String x:Key="L_TT_Settings">Настройки (Ctrl+Shift+S)</sys:String>
    <sys:String x:Key="L_TT_AutoScroll">Автоскролл</sys:String>
    <sys:String x:Key="L_TT_SendNow">Отправить сейчас (не ждать паузу)</sys:String>
    <sys:String x:Key="L_TT_Export">Экспорт транскрипта</sys:String>
    <sys:String x:Key="L_TT_Protocol">AI-протокол встречи</sys:String>
    <sys:String x:Key="L_TT_Screenshot">Режим скриншота (Ctrl+Shift+C)</sys:String>
    <sys:String x:Key="L_TT_SlowSpeech">Медленная речь (пауза длиннее)</sys:String>
    <sys:String x:Key="L_TT_ResetSpeed">Обычная речь (сбросить)</sys:String>
    <sys:String x:Key="L_TT_FastSpeech">Быстрая речь (пауза короче)</sys:String>
    <sys:String x:Key="L_TT_Cloak">Сквозной режим (клики насквозь)</sys:String>
