<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ВАЖНО: все ссылки на кисти темы — только DynamicResource (AGENTS.md §16),
         иначе ломается живое переключение HackerTheme/LightTheme. -->

    <Style TargetType="Window" x:Key="DarkWindow">
        <Setter Property="Background" Value="{DynamicResource BgBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
    </Style>

    <!-- TextBox со скруглёнными углами (дизайн-система: inputs rounded-md 8px) -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource TextDimBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="Padding" Value="6,4"/>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="Padding" Value="6,4"/>
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="Margin" Value="0,4"/>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="Padding" Value="10,5"/>
    </Style>

    <!-- Слайдер по Overlay Final 6a: трек 4px #1e2740, заливка градиент #5b63e6→#8fa8ff,
         thumb 13px белый. Значение показывается в подписи НАД треком (в месте использования). -->
    <Style x:Key="GreenSlider" TargetType="Slider">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="Height" Value="16"/>
        <!-- Клик по треку ставит бегунок в точку клика (а не листает шагами) -->
        <Setter Property="IsMoveToPointEnabled" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid VerticalAlignment="Center">
                        <Border Height="4" CornerRadius="3" Background="{DynamicResource BgLightBrush}" Margin="6,0"/>
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="4" CornerRadius="3" Background="{DynamicResource SliderFillBrush}" Margin="6,0,0,0"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Background="Transparent" Height="16"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Width="13" Height="13">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Ellipse Width="13" Height="13" Fill="#ffffff">
                                                <Ellipse.Effect>
                                                    <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="2" Opacity="0.5"/>
                                                </Ellipse.Effect>
                                            </Ellipse>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Global ToolTip style: тёмная скруглённая подсказка с тенью (в стиле оверлея).
         ControlTemplate нужен для CornerRadius + тени. Применяется и в оверлее, и в настройках. -->
    <Style TargetType="ToolTip">
        <!-- Фон тултипа ВСЕГДА тёмный (#1B2438), поэтому текст фиксированно светлый —
             иначе в светлой теме TextBrightBrush становится тёмным и текст пропадает. -->
        <Setter Property="Foreground" Value="#EEF3FB"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="HasDropShadow" Value="False"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="MaxWidth" Value="280"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="#F21B2438" BorderBrush="#3D5BD6" BorderThickness="1"
                            CornerRadius="9" Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect Color="#05070d" BlurRadius="18" ShadowDepth="5" Opacity="0.55"/>
                        </Border.Effect>
                        <TextBlock Text="{TemplateBinding Content}" Foreground="#EEF3FB" FontSize="12" TextWrapping="Wrap"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modern Slim Scrollbar -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Width="8">
                        <Border Background="{DynamicResource BgMediumBrush}" Opacity="0.5" CornerRadius="4"/>
                        <Track x:Name="PART_Track" IsDirectionReversed="True" Width="8">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{x:Null}" Visibility="Collapsed"/>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{x:Null}" Visibility="Collapsed"/>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Width="6" MinHeight="24">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border x:Name="ThumbBorder" Background="{DynamicResource AccentBrush}" Opacity="0.3" CornerRadius="3" Width="6" HorizontalAlignment="Center"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ThumbBorder" Property="Width" Value="8"/>
                                                    <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.8"/>
                                                    <Setter TargetName="ThumbBorder" Property="CornerRadius" Value="4"/>
                                                </Trigger>
                                                <Trigger Property="IsDragging" Value="True">
                                                    <Setter TargetName="ThumbBorder" Property="Width" Value="8"/>
                                                    <Setter TargetName="ThumbBorder" Property="Opacity" Value="1.0"/>
                                                    <Setter TargetName="ThumbBorder" Property="CornerRadius" Value="4"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <!-- Горизонтальный скроллбар: та же слим-стилистика, повёрнутая -->
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Height="8">
                                <Border Background="{DynamicResource BgMediumBrush}" Opacity="0.5" CornerRadius="4"/>
                                <Track x:Name="PART_Track" Height="8">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{x:Null}" Visibility="Collapsed"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{x:Null}" Visibility="Collapsed"/>
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Height="6" MinWidth="24">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border x:Name="ThumbBorder" Background="{DynamicResource AccentBrush}" Opacity="0.3" CornerRadius="3" Height="6" VerticalAlignment="Center"/>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ThumbBorder" Property="Height" Value="8"/>
                                                            <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.8"/>
                                                        </Trigger>
                                                        <Trigger Property="IsDragging" Value="True">
                                                            <Setter TargetName="ThumbBorder" Property="Height" Value="8"/>
                                                            <Setter TargetName="ThumbBorder" Property="Opacity" Value="1.0"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ProgressBar: тёмный трек r6 + индиго-градиент заливка; индетерминантный режим —
         «бегущий» блик. Глобального стиля не было — добавлен для окна транскрибации. -->
    <Style TargetType="ProgressBar">
        <Setter Property="Height" Value="8"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentGradientBrush}"/>
        <Setter Property="Background" Value="{DynamicResource BgLightBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}" CornerRadius="6" ClipToBounds="True">
                        <Grid x:Name="PART_Track">
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}" CornerRadius="6"/>
                            <Border x:Name="Glow" HorizontalAlignment="Left" Width="140" CornerRadius="6"
                                    Visibility="Collapsed">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#006f8cff" Offset="0"/>
                                        <GradientStop Color="#8f8fa8ff" Offset="0.5"/>
                                        <GradientStop Color="#006f8cff" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="GlowT" X="-140"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsIndeterminate" Value="True">
                            <Setter TargetName="PART_Indicator" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="Glow" Property="Visibility" Value="Visible"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard Name="GlowSb">
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="GlowT" Storyboard.TargetProperty="X"
                                                         From="-140" To="1200" Duration="0:0:1.4"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="GlowSb"/>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
